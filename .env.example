# Lavu App Configuration Template
# Copy this to lib/config/app_config.dart and fill in your credentials

# SUPABASE CONFIGURATION (Flutter App)
# Get these from https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SAFARICOM DARAJA M-PESA CONFIGURATION
# Get these from https://developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_BUSINESS_SHORTCODE=174379  # Or your business shortcode
DARAJA_PASSKEY=your_passkey_here

# RENDER BACKEND CONFIGURATION
# Get this from your Render dashboard after deployment
RENDER_BACKEND_URL=https://your-app.onrender.com/api

# ═══════════════════════════════════════════════════════════
# PYTHON BACKEND CONFIGURATION (.env for main.py)
# ═══════════════════════════════════════════════════════════

# DATABASE (Python Backend)
DATABASE_URL=postgresql://user:password@localhost:5432/lavu

# M-PESA (SAFARICOM DARAJA) - Python Backend
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# EMAIL (SENDGRID) - Python Backend
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx_your_api_key_here
SENDGRID_FROM_EMAIL=noreply@lavulaundry.com
SUPPORT_EMAIL=support@lavulaundry.com

# APP SETTINGS
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# DEPLOYMENT
ENVIRONMENT=development
DEBUG=true

